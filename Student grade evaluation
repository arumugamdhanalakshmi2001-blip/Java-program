import java.util.Scanner;

public class StudentGrade {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int marks;
        char grade;

        System.out.print("Enter student marks: ");
        marks = sc.nextInt();

        if (marks >= 90) {
            grade = 'A';
        } 
        else if (marks >= 80) {
            grade = 'B';
        } 
        else if (marks >= 70) {
            grade = 'C';
        } 
        else if (marks >= 60) {
            grade = 'D';
        } 
        else {
            grade = 'F';
        }

        System.out.println("Student Grade: " + grade);
    }
}
